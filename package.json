{
  "name": "loot-monorepo",
  "version": "1.0.0",
  "description": "FLOW + SPIN + SMASH \u2014 Deterministic writing tools with shared engine",
  "private": true,
  "workspaces": [
    "packages/loom",
    "packages/shared",
    "packages/loom",
    "packages/flow",
    "packages/spin",
    "packages/smash"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "test:loom": "npm test -w packages/loom",
    "test:shared": "npm test -w packages/shared",
    "test:flow": "npm test -w packages/flow",
    "test:spin": "npm test -w packages/spin",
    "test:smash": "npm test -w packages/smash",
    "gate:phase5": "node scripts/phase5_quality_gate.js",
    "bench:manifest": "node scripts/phase6_benchmark_hardening.js",
    "gate:phase6": "npm run gate:phase5 && npm run bench:manifest",
    "bench:lrs-pairs": "node scripts/lrs_word_pairs_eval.js",
    "test:flow-longtexts": "node scripts/test_flow_longtexts.js"
  },
  "keywords": [
    "normalization",
    "orthography",
    "diagnosis",
    "writing",
    "neurodivergent",
    "german",
    "english",
    "deterministic"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0"
  }
}
